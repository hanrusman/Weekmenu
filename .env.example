DATABASE_PATH=./data/weekmenu.db
PORT=3000
TZ=Europe/Amsterdam

# Bearer token used by Home Assistant sensor to read /api/today.
# Generate: openssl rand -base64 48
HA_API_TOKEN=

# Who may embed the app in an iframe. Default 'self' (same-origin only).
# To allow Home Assistant: FRAME_ANCESTORS="'self' https://ha.example.com"
#FRAME_ANCESTORS='self'
